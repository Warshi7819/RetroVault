@page
@model RetroVaultWebApp.Pages.DetailsModel
@{
    ViewData["Title"] = "Details";
}

@if (Model.Item == null)
{
    <h2>Item not found</h2>
    <a asp-page="Index" class="btn btn-secondary mt-3">Back</a>
}
else
{
    <div class="container mt-3">

        <div class="row">
            <div class="col-12 text-center mb-3">
                <!-- Thumbnail -->
                <img src="/images/thumbnails/@(Model.Item.Id).png"
                     alt="@Model.Item.Name thumbnail"
                     class="img-fluid rounded shadow-sm"
                     style="max-height: 200px; object-fit: contain;" />
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">

                <h5 class="card-title mb-3">@Model.Item.Name</h5>

                <table class="table table-sm table-striped">
                    <tbody>
                        <tr><th>System</th><td>@Model.Item.System</td></tr>
                        <tr><th>Category</th><td>@Model.Item.Category</td></tr>
                        <tr><th>Region</th><td>@Model.Item.Region</td></tr>
                        <tr><th>Developer</th><td>@Model.Item.Developer</td></tr>
                        <tr><th>Publisher</th><td>@Model.Item.Publisher</td></tr>
                        <tr><th>Year</th><td>@Model.Item.Year</td></tr>
                        <tr><th>Acquired</th><td>@Model.Item.AcquiredDate (@Model.Item.AcquiredFrom)</td></tr>
                        <tr><th>Completeness</th><td>@Model.Item.Completeness</td></tr>
                        <tr><th>Storage Location</th><td>@Model.Item.StorageLocation</td></tr>
                        <tr><th>Purchase Price</th><td>@Model.Item.PurchasePrice @Model.Item.Currency</td></tr>
                        <tr><th>Description</th><td style="white-space: pre-wrap;">@Model.Item.Description</td></tr>
                    </tbody>
                </table>


            </div>
        </div>

        <div class="mt-3">
            <a asp-page="Index"
               asp-route-name="@Model.Name"
               asp-route-system="@Model.System"
               asp-route-category="@Model.Category"
               asp-route-pageNumber="@Model.PageNumber"
               asp-route-search="true"
               class="btn btn-secondary">
                Back to Search
            </a>
        </div>

    </div>
}
