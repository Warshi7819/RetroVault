@page
@model IndexModel
@{
    ViewData["Title"] = "The Vault";
}
@using System.Text.Encodings.Web

<form method="get">
    <div class="row mb-3">

        <div class="col">
            <input class="form-control" name="Name" value="@Model.Name" placeholder="Name" />
        </div>

        <div class="col">
            <select class="form-select" name="System">
                @foreach (var sys in Model.Systems)
                {
                    <option value="@sys" selected="@(sys == Model.System)">
                        @sys
                    </option>
                }
            </select>
        </div>

        <div class="col">
            <select class="form-select" name="Category">
                @foreach (var cat in Model.Categories)
                {
                    <option value="@cat" selected="@(cat == Model.Category)">
                        @cat
                    </option>
                }
            </select>
        </div>

        <div class="col">
            <button class="btn btn-primary"
                type="submit"
                name="Search"
                value="true"
                data-clear-scroll>Search
            </button>
        </div>
    </div>
</form>


@if (!Model.Search)
{
    <br/>
    <div class="container">
        <div class="row">
            <div class="col-4 mx-auto">
                <img src="images/Splash.png" class="img-fluid" alt="The Vault" />
            </div>
        </div>
    </div>
}
else if (Model.Results == null || !Model.Results.Items.Any())
{
    <p>No results found.</p>
}
else
{
     <ul class="list-group mb-3">
        @foreach (var item in Model.Results.Items)
        {
            <li class="list-group-item p-0 border-0 bg-transparent">
                <div class="row align-items-center mb-3 p-2 border rounded"
                     style="cursor: pointer;"
                     data-nav="@Url.Page("Details", new {
                         id = item.Id,
                         name = Model.Name,
                         system = Model.System,
                         category = Model.Category,
                         pageNumber = Model.PageNumber,
                         search = true
                     })">

                    <!-- LEFT COLUMN -->
                    <div class="col-8">
                        <div class="fw-bold fs-5">@item.Name</div>
                        <div><strong>System:</strong> @item.System</div>
                        <div><strong>Category:</strong> @item.Category</div>
                        <div><strong>Year:</strong> @item.Year</div>
                    </div>

                    <!-- RIGHT COLUMN -->
                    <div class="col-4 text-end">
                        <img src="images/thumbnails/@(item.Id).png"
                             alt="@item.Name thumbnail"
                             class="img-fluid rounded"
                             style="max-height: 120px; object-fit: contain;"
                             data-fallback="/images/detective.png" />
                    </div>
                </div>
            </li>
        }
    </ul>

    <!-- Pagination -->
    <nav>
        <ul class="pagination">

            @if (Model.PageNumber > 1)
            {
                <li class="page-item">
                    <a class="page-link"
                       asp-route-Name="@Model.Name"
                       asp-route-System="@Model.System"
                       asp-route-Category="@Model.Category"
                       asp-route-PageNumber="@(Model.PageNumber - 1)"
                       asp-route-search="true"
                       data-reset-scroll>
                        Previous
                    </a>
                </li>
            }

            <li class="page-item disabled">
                <span class="page-link">
                    Page @Model.PageNumber of @Model.Results.TotalPages
                </span>
            </li>

            @if (Model.PageNumber < Model.Results.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link"
                       asp-route-Name="@Model.Name"
                       asp-route-System="@Model.System"
                       asp-route-Category="@Model.Category"
                       asp-route-PageNumber="@(Model.PageNumber + 1)"
                       asp-route-search="true"
                       data-reset-scroll>
                        Next
                    </a>
                </li>
            }
        </ul>
    </nav>
}

<!-- I hate JavaScript, the following is therefore produced by AI -->
<script nonce="@(HttpContext.Items["CSP-Nonce"])">
    const scrollKey = "retroVaultScroll";
    const skipKey = "retroVaultSkipScrollSave";

    function resetScrollAndSkipSave() {
        sessionStorage.setItem(skipKey, "true");
        sessionStorage.removeItem(scrollKey);
        return true;
    }

    document.addEventListener("DOMContentLoaded", () => {
        // Restore scroll
        const saved = sessionStorage.getItem(scrollKey);
        if (saved) {
            window.scrollTo(0, parseInt(saved));
        }
        sessionStorage.removeItem(skipKey);

        // Search button: clear scroll
        document.querySelectorAll("[data-clear-scroll]")
            .forEach(el =>
                el.addEventListener("click", () => {
                    sessionStorage.removeItem(scrollKey);
                }));

        // Pagination: use resetScrollAndSkipSave
        document.querySelectorAll("[data-reset-scroll]")
            .forEach(el =>
                el.addEventListener("click", e => {
                    if (!resetScrollAndSkipSave()) {
                        e.preventDefault();
                    }
                }));

        // Clickable rows: navigate via data-nav
        document.querySelectorAll("[data-nav]")
            .forEach(el =>
                el.addEventListener("click", () => {
                    const target = el.getAttribute("data-nav");
                    if (target) window.location = target;
                }));

        // Image fallback instead of onerror
        document.querySelectorAll("img[data-fallback]")
            .forEach(img => {
                img.addEventListener("error", () => {
                    const fallback = img.getAttribute("data-fallback");
                    if (fallback) img.src = fallback;
                });
            });
    });

    window.addEventListener("beforeunload", () => {
        const skip = sessionStorage.getItem(skipKey);
        if (skip === "true") return;
        sessionStorage.setItem(scrollKey, window.scrollY.toString());
    });
</script>

